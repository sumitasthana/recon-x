# Base URL of the FastAPI backend (reconx-prototype/api/server.py).
# Leave empty in local dev — the Vite proxy in vite.config.js forwards
# /api/* to http://localhost:8000.
# In production (Vercel), set this to the deployed backend's public URL,
# e.g. https://reconx-api.fly.dev — no trailing slash.
VITE_API_BASE_URL=
