<AxiomSLConfiguration
    xmlns="http://www.axiomsl.com/controllerView/schema/v4.2"
    configType="ScheduleRoutingConfiguration"
    module="FR2590"
    version="5.1.0"
    effectiveDate="2026-03-31"
    exportedAt="2026-04-10T08:00:00Z">

    <ConfigMetadata>
        <Description>Exposure type to FR 2590 schedule routing rules. Maps each incoming exposure_type_code to the correct FR 2590 schedule (G-1 through G-5, M-1, M-2, A-1, A-2, Summary). Based on FR 2590 reporting instructions.</Description>
        <FedSource>FR 2590 Reporting Instructions (OMB 7100-0377)</FedSource>
        <LastValidatedAgainstFed>2025-06-30</LastValidatedAgainstFed>
    </ConfigMetadata>

    <RoutingRules totalExposureTypes="42">

        <!-- SCHEDULE G-1: General Exposures -->
        <RouteGroup targetSchedule="G-1" scheduleName="General_Exposures">
            <Description>General credit exposures — deposits, loans, debt/equity securities, committed credit lines, guarantees/letters of credit, securitization look-through. Amounts in thousands USD.</Description>
            <ExposureTypes>
                <ExposureType code="GE.1" name="Deposits"/>
                <ExposureType code="GE.2" name="Loans and Leases"/>
                <ExposureType code="GE.3" name="Debt Securities or Investments"/>
                <ExposureType code="GE.4" name="Equity Securities or Investments"/>
                <ExposureType code="GE.5" name="Committed Credit Lines"/>
                <ExposureType code="GE.6" name="Guarantees and Letters of Credit"/>
                <ExposureType code="GE.7" name="Securitization — Look-Through"/>
                <!-- 5 more general exposure sub-types -->
            </ExposureTypes>
            <AmountField>gross_credit_exposure_usd</AmountField>
            <AggregationLevel>COUNTERPARTY</AggregationLevel>
            <MaxCounterparties>50</MaxCounterparties>
        </RouteGroup>

        <!-- SCHEDULE G-2: Repurchase Agreement Exposures -->
        <RouteGroup targetSchedule="G-2" scheduleName="Repo_Exposures">
            <Description>Gross credit exposure from repurchase agreements and reverse repurchase agreements. Includes tri-party, bilateral, and GCF repo.</Description>
            <ExposureTypes>
                <ExposureType code="RP.1" name="Reverse Repo — Bilateral"/>
                <ExposureType code="RP.2" name="Reverse Repo — Tri-Party"/>
                <ExposureType code="RP.3" name="Reverse Repo — GCF"/>
                <ExposureType code="RP.4" name="Repo — Bilateral"/>
                <ExposureType code="RP.5" name="Repo — Tri-Party"/>
                <!-- 3 more repo exposure types -->
            </ExposureTypes>
            <AmountField>gross_credit_exposure_usd</AmountField>
            <HaircutRequired>true</HaircutRequired>
            <CollateralValuationSource>MARK_TO_MARKET</CollateralValuationSource>
        </RouteGroup>

        <!-- SCHEDULE G-3: Securities Lending Exposures -->
        <RouteGroup targetSchedule="G-3" scheduleName="SecLending_Exposures">
            <Description>Gross credit exposure from securities lending and securities borrowing transactions.</Description>
            <ExposureTypes>
                <ExposureType code="SL.1" name="Securities Lending — Cash Collateral"/>
                <ExposureType code="SL.2" name="Securities Lending — Non-Cash Collateral"/>
                <ExposureType code="SL.3" name="Securities Borrowing — Cash Collateral"/>
                <ExposureType code="SL.4" name="Securities Borrowing — Non-Cash Collateral"/>
            </ExposureTypes>
            <AmountField>gross_credit_exposure_usd</AmountField>
            <HaircutRequired>true</HaircutRequired>
        </RouteGroup>

        <!-- SCHEDULE G-4: Derivatives Exposures -->
        <RouteGroup targetSchedule="G-4" scheduleName="Derivatives_Exposures">
            <Description>Gross credit exposure from derivative contracts. Exposure calculated per ExposureMethodConfig.xml (currently CEM as of v5.1.0).</Description>
            <ExposureTypes>
                <ExposureType code="DV.1" name="Interest Rate Derivatives"/>
                <ExposureType code="DV.2" name="FX Derivatives"/>
                <ExposureType code="DV.3" name="Credit Derivatives — Protection Bought"/>
                <ExposureType code="DV.4" name="Credit Derivatives — Protection Sold"/>
                <ExposureType code="DV.5" name="Equity Derivatives"/>
                <ExposureType code="DV.6" name="Commodity Derivatives"/>
                <!-- 4 more derivative exposure types -->
            </ExposureTypes>
            <AmountField>gross_credit_exposure_usd</AmountField>
            <MethodReference>ExposureMethodConfig.xml</MethodReference>
            <!-- Exposure method from ExposureMethodConfig.xml applied to all G-4 exposures.
                 Method change in v5.1.0 (CEM revert) is the root cause
                 of BRK-S01 for FX and equity derivative exposures to top counterparties. -->
        </RouteGroup>

        <!-- SCHEDULE G-5: Risk Shifting Exposures -->
        <RouteGroup targetSchedule="G-5" scheduleName="RiskShifting_Exposures">
            <Description>Gross credit exposure arising from risk shifting — credit derivatives where the covered company is the protection buyer and the counterparty is the reference entity. Also includes look-through exposures from securitizations where beneficial owner attribution is required.</Description>
            <ExposureTypes>
                <ExposureType code="RS.1" name="Credit Risk Shifting — CDS Single Name"/>
                <ExposureType code="RS.2" name="Credit Risk Shifting — CDS Index"/>
                <ExposureType code="RS.3" name="Securitization Look-Through — CLO"/>
                <ExposureType code="RS.4" name="Securitization Look-Through — ABCP"/>
                <ExposureType code="RS.5" name="Securitization Look-Through — RMBS"/>
                <!-- Look-through exposures with beneficial_owner_lei=NULL:
                     IngestionFilter BENEFICIAL_OWNER_NULL_EXCL (SILENT) will exclude
                     these records before they reach routing. This means exposures
                     that should be reported as "unknown counterparty" in G-5 are
                     instead silently dropped. Root cause of BRK-S04. -->
            </ExposureTypes>
            <LookThroughRequired>true</LookThroughRequired>
            <NullBeneficialOwnerAction>REPORT_AS_UNKNOWN_COUNTERPARTY</NullBeneficialOwnerAction>
            <!-- NOTE: NullBeneficialOwnerAction config is IGNORED because the
                 IngestionFilter runs BEFORE routing and silently excludes these
                 exposures. Config says REPORT_AS_UNKNOWN_COUNTERPARTY but it
                 never fires for filtered records. Identical pattern to FR 2052a
                 BRK-004 (forward start null exclusion). -->
        </RouteGroup>

        <!-- SCHEDULE M-1: Eligible Collateral -->
        <RouteGroup targetSchedule="M-1" scheduleName="Eligible_Collateral">
            <Description>Eligible collateral reducing gross credit exposure to net credit exposure per 12 CFR 252.74. Financial collateral, cash, and certain debt securities qualify.</Description>
            <ExposureTypes>
                <ExposureType code="MC.1" name="Cash Collateral"/>
                <ExposureType code="MC.2" name="US Treasury Collateral"/>
                <ExposureType code="MC.3" name="US Agency Collateral"/>
                <ExposureType code="MC.4" name="Investment Grade Corporate Bond Collateral"/>
                <ExposureType code="MC.5" name="Equity Collateral"/>
            </ExposureTypes>
            <Direction>REDUCING</Direction>
            <AmountField>eligible_collateral_value_usd</AmountField>
        </RouteGroup>

        <!-- SCHEDULE M-2: General Risk Mitigants -->
        <RouteGroup targetSchedule="M-2" scheduleName="Risk_Mitigants">
            <Description>Other eligible risk mitigants — eligible guarantees, eligible credit derivatives, and other eligible hedges per 12 CFR 252.74.</Description>
            <ExposureTypes>
                <ExposureType code="MR.1" name="Eligible Guarantee"/>
                <ExposureType code="MR.2" name="Eligible Credit Derivative — Protection Bought"/>
                <ExposureType code="MR.3" name="Eligible Equity Derivative — Hedge"/>
            </ExposureTypes>
            <Direction>REDUCING</Direction>
            <AmountField>risk_mitigant_value_usd</AmountField>
        </RouteGroup>

        <!-- SCHEDULE A-1: Economic Interdependence -->
        <RouteGroup targetSchedule="A-1" scheduleName="Economic_Interdependence">
            <Description>Interconnected counterparty groups identified through the economic interdependence test per 12 CFR 252.76(a). Up to 5 interdependent counterparties per group.</Description>
            <ExposureTypes>
                <ExposureType code="EI.1" name="Interdependent Counterparty Group"/>
            </ExposureTypes>
            <MaxCounterpartiesPerGroup>5</MaxCounterpartiesPerGroup>
            <GroupingSource>SCCL_CPTY_HIERARCHY.econ_interdependence_group_id</GroupingSource>
        </RouteGroup>

        <!-- SCHEDULE A-2: Control Relationships -->
        <RouteGroup targetSchedule="A-2" scheduleName="Control_Relationships">
            <Description>Control relationship groupings per 12 CFR 252.76(b). Identifies counterparties connected through voting rights, board control, or management influence.</Description>
            <ExposureTypes>
                <ExposureType code="CR.1" name="Control Relationship Group"/>
            </ExposureTypes>
            <GroupingSource>SCCL_CPTY_HIERARCHY.control_relationship_group_id</GroupingSource>
        </RouteGroup>

        <!-- SUMMARY: Net Credit Exposure Summary -->
        <RouteGroup targetSchedule="SUMMARY" scheduleName="Net_Credit_Exposure_Summary">
            <Description>Summary schedule — aggregate net credit exposure per counterparty for limit compliance testing. Net exposure = sum(G-1:G-5) - M-1 - M-2. Compared against 15% (major) or 25% (non-major) of Tier 1 capital.</Description>
            <CalculationFormula>NET_EXPOSURE = G1 + G2 + G3 + G4 + G5 - M1 - M2</CalculationFormula>
            <LimitTestReference>CounterpartyHierarchy.xml — MajorCounterpartyDefinition</LimitTestReference>
        </RouteGroup>

        <!-- Unmapped exposure type handling -->
        <UnmappedExposureTypeAction>REJECT_AND_LOG_ERROR</UnmappedExposureTypeAction>

    </RoutingRules>

</AxiomSLConfiguration>


