        </RefreshConfiguration>

        <EconomicInterdependenceTest>
            <!-- Per 12 CFR 252.76(a) — factors indicating economic interdependence -->
            <Description>Two counterparties are economically interdependent if the financial distress of one would cause financial distress to the other. The covered company must aggregate exposures to interdependent counterparties.</Description>
            <Factors>
                <Factor id="EI-1">50% or more of one counterparty's gross revenue derived from transactions with the other</Factor>
                <Factor id="EI-2">50% or more of one counterparty's gross expenditures paid to the other</Factor>
                <Factor id="EI-3">One counterparty has fully or partly guaranteed the credit exposure of the other, and the exposure is significant enough that the guarantor is likely to default if called upon</Factor>
                <Factor id="EI-4">25% or more of one counterparty's production output sold to the other</Factor>
                <Factor id="EI-5">Common primary source of funding (same parent, same lender of last resort)</Factor>
            </Factors>
            <EvaluationFrequency>QUARTERLY</EvaluationFrequency>
            <LastEvaluationDate>2025-09-30</LastEvaluationDate>
            <!-- Also stale — should have been re-evaluated in Q4 2025 and Q1 2026 -->
        </EconomicInterdependenceTest>

        <ControlRelationshipTest>
            <!-- Per 12 CFR 252.76(b) — factors indicating control relationship -->
            <Description>Two counterparties have a control relationship if one counterparty controls the other through voting rights, board representation, or management authority.</Description>
            <Factors>
                <Factor id="CR-1">One counterparty owns, controls, or holds 25% or more of any class of voting securities of the other</Factor>
                <Factor id="CR-2">One counterparty controls the election of a majority of the board of directors of the other</Factor>
                <Factor id="CR-3">One counterparty exercises a controlling influence over management or policies of the other</Factor>
            </Factors>
            <EvaluationFrequency>QUARTERLY</EvaluationFrequency>
            <LastEvaluationDate>2025-09-30</LastEvaluationDate>
        </ControlRelationshipTest>

        <CounterpartyTypeCodes>
            <!-- Per FR 2590 Counterparty Information schedule -->
            <TypeCode code="NATURAL_PERSON"         description="Natural person"/>
            <TypeCode code="COMPANY"                description="Company (incorporated entity)"/>
            <TypeCode code="CCP"                    description="Qualifying central counterparty"/>
            <TypeCode code="US_STATE_MUNI"          description="U.S. state or municipality"/>
            <TypeCode code="US_GOVERNMENT"          description="U.S. government"/>
            <TypeCode code="US_GOVT_AGENCY"         description="U.S. government agency"/>
            <TypeCode code="FOREIGN_SOVEREIGN_ZERO" description="Foreign sovereign — zero percent risk weight"/>
            <TypeCode code="FOREIGN_SOVEREIGN_NONZERO" description="Foreign sovereign — non-zero percent risk weight"/>
            <TypeCode code="POLITICAL_SUBDIVISION"  description="Political subdivision of a foreign sovereign"/>
            <TypeCode code="MULTILATERAL_DEV_BANK"  description="Multilateral development bank"/>
            <TypeCode code="SECURITIZATION"          description="Securitization vehicle (SPE)"/>
            <TypeCode code="INVESTMENT_FUND"         description="Collective investment undertaking / fund"/>
            <TypeCode code="OTHER"                  description="Other / unclassified"/>
        </CounterpartyTypeCodes>

        <MajorCounterpartyDefinition>
            <!-- Per 12 CFR 252.71(e) -->
            <Description>A major counterparty means: (1) a major covered company (U.S. GSIB), (2) an FBO that is a GSIB, or (3) a nonbank financial company supervised by the Board. Exposures to major counterparties are subject to the 15% of Tier 1 capital limit (vs 25% for non-major).</Description>
            <CreditLimit_Major_Pct>15.00</CreditLimit_Major_Pct>
            <CreditLimit_NonMajor_Pct>25.00</CreditLimit_NonMajor_Pct>
        </MajorCounterpartyDefinition>

        <LEIValidation>
            <FormatCheck>true</FormatCheck>
            <LengthRequired>20</LengthRequired>
            <CharacterSet>ALPHANUMERIC</CharacterSet>
            <ChecksumValidation>true</ChecksumValidation>
            <InvalidLEIAction>REJECT_AND_LOG_ERROR</InvalidLEIAction>
        </LEIValidation>

    </CounterpartyHierarchyTable>

</AxiomSLConfiguration>


