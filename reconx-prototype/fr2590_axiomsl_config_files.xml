<AxiomSLConfiguration
    xmlns="http://www.axiomsl.com/controllerView/schema/v4.2"
    configType="CounterpartyHierarchyConfiguration"
    module="FR2590"
    version="5.1.0"
    effectiveDate="2026-03-31"
    exportedAt="2026-04-10T08:00:00Z">

    <ConfigMetadata>
        <Description>Counterparty hierarchy configuration for FR 2590 SCCL. Manages economic interdependence grouping (Schedule A-1), control relationship grouping (Schedule A-2), and affiliate aggregation. The SCCL rule requires that exposures to economically interdependent counterparties and to counterparties connected through control relationships be aggregated for limit testing purposes.</Description>
    </ConfigMetadata>

    <CounterpartyHierarchyTable>

        <PrimaryTable>
            <Schema>AXIOM</Schema>
            <TableName>FR2590.SCCL_CPTY_HIERARCHY</TableName>
            <FullyQualifiedName>AXIOM.FR2590.SCCL_CPTY_HIERARCHY</FullyQualifiedName>
            <KeyField>lei</KeyField>
            <ActiveFlag>active</ActiveFlag>
            <MajorStatusField>is_major_counterparty</MajorStatusField>
            <ExemptionStatusField>exemption_status</ExemptionStatusField>
            <ParentGroupField>counterparty_group_id</ParentGroupField>
            <InterdependenceGroupField>econ_interdependence_group_id</InterdependenceGroupField>
            <ControlGroupField>control_relationship_group_id</ControlGroupField>
        </PrimaryTable>

        <RefreshConfiguration>
            <LastRefreshDate>2025-11-15</LastRefreshDate>
            <!-- STALE: Table not refreshed in 147 days as of 2026-04-10.
                 Multiple hierarchy changes since last refresh:
                   1. Q4 2025: MegaCorp Inc acquired SubCo Alpha (LEI: 529900T8BM49AURSDO55)
                      and SubCo Beta (LEI: 529900HZLJ7K4X2YPR82). These two entities
                      should now be grouped under MegaCorp's counterparty group
                      (group_id: GRP-0042) for aggregate limit testing.
                      Snowflake DIM_CPTY_HIERARCHY updated 2025-12-20.
                      AxiomSL SCCL_CPTY_HIERARCHY: NOT UPDATED.
                      Without grouping: MegaCorp exposure = 18.2% of Tier 1.
                      With correct grouping: MegaCorp + SubCo Alpha + SubCo Beta = 23.7%.
                      Difference of 5.5% — material for limit monitoring.
                   2. Jan 2026: GreenEnergy Fund reclassified from NON_MAJOR to MAJOR
                      per FSOC designation. Limit drops from 25% to 15% of Tier 1.
                      Not reflected in AxiomSL hierarchy table.
                   = BRK-S02. Severity: HIGH. -->
            <ScheduledRefreshFrequency>QUARTERLY</ScheduledRefreshFrequency>
            <NextScheduledRefresh>2026-03-31</NextScheduledRefresh>
            <!-- Refresh deferred per JIRA-REG-5044 due to hierarchy data model migration -->
            <DeferralReason>Counterparty hierarchy data model migration from flat table to graph structure. Migration in progress — estimated completion Q2 2026.</DeferralReason>
            <DeferralApprovedBy>Head of Credit Risk Technology</DeferralApprovedBy>
            <DeferralTicket>JIRA-REG-5044</DeferralTicket>
            <RecordCount>1247</RecordCount>
            <GroupCount>312</GroupCount>
            <MissingFromRefresh>
                <Entity lei="529900T8BM49AURSDO55" name="SubCo Alpha LLC" acquiredBy="GRP-0042" acquiredDate="2025-10-15">Should be grouped under MegaCorp Inc (GRP-0042)</Entity>
                <Entity lei="529900HZLJ7K4X2YPR82" name="SubCo Beta Holdings" acquiredBy="GRP-0042" acquiredDate="2025-11-01">Should be grouped under MegaCorp Inc (GRP-0042)</Entity>
