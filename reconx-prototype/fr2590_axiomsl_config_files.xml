<AxiomSLConfiguration
    xmlns="http://www.axiomsl.com/controllerView/schema/v4.2"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.axiomsl.com/controllerView/schema/v4.2 cv-schema-v4.2.xsd"
    configType="ExposureMethodConfiguration"
    module="FR2590"
    version="5.1.0"
    effectiveDate="2026-03-31"
    previousVersion="5.0.2"
    changeTicket="JIRA-REG-5102"
    exportedBy="axiom-admin"
    exportedAt="2026-04-10T08:00:00Z">

    <ConfigMetadata>
        <Description>Gross credit exposure calculation methodology for FR 2590 SCCL reporting. Controls how derivative exposures are converted to credit equivalent amounts for Schedule G-4. Changed in v5.1.0 from SA-CCR back to CEM as primary method per internal model governance review. SA-CCR retained as approved alternative but demoted to secondary.</Description>
        <ChangeReason>Internal model governance committee determined CEM implementation had longer operational track record and fewer reconciliation breaks. SA-CCR implementation flagged for additional parallel-run validation through Q3 2026.</ChangeReason>
        <ApprovedBy>Head of Counterparty Credit Risk</ApprovedBy>
        <ApprovalDate>2026-03-15</ApprovalDate>
        <TestingCompletedBy>Model Validation Group</TestingCompletedBy>
        <TestingDate>2026-03-28</TestingDate>
    </ConfigMetadata>

    <ExposureMethodConfiguration>

        <DerivativeExposureMethod>

            <PrimaryMethod id="CEM" priority="1" isActive="true">
                <MethodName>Current Exposure Method</MethodName>
                <RegulatoryBasis>12 CFR Part 252.73(a)(5)(i) — gross credit exposure from derivatives</RegulatoryBasis>
                <Description>CEM calculates gross credit exposure as the sum of current credit exposure (positive mark-to-market) plus potential future exposure (notional × add-on factor by asset class and remaining maturity).</Description>
                <CalculationComponents>
                    <Component id="CCE">
                        <Name>Current Credit Exposure</Name>
                        <Formula>MAX(0, mark_to_market_value_usd)</Formula>
                    </Component>
                    <Component id="PFE">
                        <Name>Potential Future Exposure</Name>
                        <Formula>notional_amount_usd × add_on_factor</Formula>
                    </Component>
                    <Component id="GROSS">
                        <Name>Gross Credit Exposure</Name>
                        <Formula>CCE + PFE</Formula>
                    </Component>
                </CalculationComponents>
                <AddOnFactors>
                    <!-- Per 12 CFR Part 252, Table 1 — CEM conversion factors -->
                    <Factor assetClass="INTEREST_RATE" remainingMaturity="LTE_1Y">0.00</Factor>
                    <Factor assetClass="INTEREST_RATE" remainingMaturity="1Y_TO_5Y">0.005</Factor>
                    <Factor assetClass="INTEREST_RATE" remainingMaturity="GT_5Y">0.015</Factor>
                    <Factor assetClass="FX"            remainingMaturity="LTE_1Y">0.01</Factor>
                    <Factor assetClass="FX"            remainingMaturity="1Y_TO_5Y">0.05</Factor>
                    <Factor assetClass="FX"            remainingMaturity="GT_5Y">0.075</Factor>
                    <Factor assetClass="EQUITY"        remainingMaturity="LTE_1Y">0.06</Factor>
                    <Factor assetClass="EQUITY"        remainingMaturity="1Y_TO_5Y">0.08</Factor>
                    <Factor assetClass="EQUITY"        remainingMaturity="GT_5Y">0.10</Factor>
                    <Factor assetClass="CREDIT"        remainingMaturity="LTE_1Y">0.05</Factor>
                    <Factor assetClass="CREDIT"        remainingMaturity="1Y_TO_5Y">0.05</Factor>
                    <Factor assetClass="CREDIT"        remainingMaturity="GT_5Y">0.05</Factor>
                    <Factor assetClass="COMMODITY"     remainingMaturity="LTE_1Y">0.10</Factor>
                    <Factor assetClass="COMMODITY"     remainingMaturity="1Y_TO_5Y">0.12</Factor>
                    <Factor assetClass="COMMODITY"     remainingMaturity="GT_5Y">0.15</Factor>
                </AddOnFactors>
                <!-- NOTE FOR RCA AGENT:
                     Snowflake pipeline uses SA-CCR (adopted Q1 2025 after Board approval).
                     SA-CCR produces materially different PFE for FX and equity derivatives:
                       - FX 1-5Y: SA-CCR alpha×(RC+PFE) vs CEM notional×0.05
                       - On $2.1B notional FX book to top-5 counterparty XYZ Corp:
                         CEM gross = $148.2M, SA-CCR gross = $126.7M, delta = $21.5M
                       - This pushes XYZ Corp from 22.8% to 24.1% of Tier 1 capital in CEM,
                         potentially breaching 25% limit under stress = BRK-S01.
                     Severity: HIGH -->
            </PrimaryMethod>

            <ApprovedAlternativeMethod id="SA_CCR" priority="2" isActive="true">
                <MethodName>Standardized Approach for Counterparty Credit Risk</MethodName>
                <RegulatoryBasis>12 CFR Part 252.73(a)(5)(ii) — SA-CCR as permitted alternative</RegulatoryBasis>
                <Description>SA-CCR calculates exposure as alpha × (replacement cost + potential future exposure), where PFE is driven by hedging set aggregation and delta-adjusted notionals.</Description>
                <AlphaFactor>1.4</AlphaFactor>
                <BoardApprovalDate>2025-01-15</BoardApprovalDate>
                <BoardApprovalTicket>JIRA-MOD-3891</BoardApprovalTicket>
                <ParallelRunStatus>ACTIVE</ParallelRunStatus>
                <ParallelRunEndDate>2026-09-30</ParallelRunEndDate>
                <!-- Demoted from primary in v5.1.0. Was primary in v5.0.0 through v5.0.2.
                     Parallel run continues to compare CEM vs SA-CCR outputs. -->
            </ApprovedAlternativeMethod>

        </DerivativeExposureMethod>

        <SecuritiesFinancingExposure>
            <Method>COLLATERAL_HAIRCUT</Method>
            <Description>Gross credit exposure from repo/reverse repo and securities lending calculated as: exposure = MAX(0, (market_value_lent - market_value_collateral_received × (1 - haircut))). Haircuts per 12 CFR Part 252.73(a)(3).</Description>
            <Haircuts>
                <Haircut collateralType="US_TREASURY" residualMaturity="LTE_1Y">0.005</Haircut>
                <Haircut collateralType="US_TREASURY" residualMaturity="1Y_TO_5Y">0.02</Haircut>
                <Haircut collateralType="US_TREASURY" residualMaturity="GT_5Y">0.04</Haircut>
                <Haircut collateralType="US_AGENCY"   residualMaturity="LTE_1Y">0.01</Haircut>
                <Haircut collateralType="US_AGENCY"   residualMaturity="1Y_TO_5Y">0.03</Haircut>
                <Haircut collateralType="US_AGENCY"   residualMaturity="GT_5Y">0.06</Haircut>
                <Haircut collateralType="EQUITY"       residualMaturity="ALL">0.15</Haircut>
                <Haircut collateralType="CORPORATE_BOND" residualMaturity="ALL">0.10</Haircut>
                <Haircut collateralType="CASH"         residualMaturity="ALL">0.00</Haircut>
            </Haircuts>
        </SecuritiesFinancingExposure>

        <FXConversion>
            <RateSource>ECB_REF</RateSource>
            <RateType>PRIOR_DAY_CLOSE</RateType>
            <Description>All non-USD exposures converted to USD using ECB reference rates. Consistent with FXRateConfig used in FR 2052a module (shared rate source).</Description>
        </FXConversion>

        <VersionHistory>
            <Version id="5.0.0" date="2025-01-15">SA-CCR adopted as primary method per Board approval</Version>
            <Version id="5.0.1" date="2025-06-01">SA-CCR hedging set calibration update</Version>
            <Version id="5.0.2" date="2025-12-01">SA-CCR alpha factor confirmed at 1.4</Version>
            <Version id="5.1.0" date="2026-03-31">Reverted to CEM as primary. SA-CCR demoted to parallel run.</Version>
        </VersionHistory>

    </ExposureMethodConfiguration>

</AxiomSLConfiguration>


