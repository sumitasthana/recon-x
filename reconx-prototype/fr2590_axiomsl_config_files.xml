<AxiomSLConfiguration
    xmlns="http://www.axiomsl.com/controllerView/schema/v4.2"
    configType="ExemptionReferenceConfiguration"
    module="FR2590"
    version="5.1.0"
    effectiveDate="2026-03-31"
    exportedAt="2026-04-10T08:00:00Z">

    <ConfigMetadata>
        <Description>Counterparty exemption reference table configuration. Manages exemption status for counterparties under the SCCL rule per 12 CFR 252.77(a). Exposures to exempt counterparties are excluded from SCCL limit testing but must still be reported on the FR 2590 form.</Description>
    </ConfigMetadata>

    <ExemptionReferenceTable>

        <PrimaryTable>
            <Schema>AXIOM</Schema>
            <TableName>FR2590.SCCL_EXEMPTION_REF</TableName>
            <FullyQualifiedName>AXIOM.FR2590.SCCL_EXEMPTION_REF</FullyQualifiedName>
            <KeyField>counterparty_lei</KeyField>
            <ExemptionStatusField>exemption_status</ExemptionStatusField>
            <ExemptionCategoryField>exemption_category</ExemptionCategoryField>
            <EffectiveDateField>effective_date</EffectiveDateField>
            <ExpiryDateField>expiry_date</ExpiryDateField>
        </PrimaryTable>

        <RefreshConfiguration>
            <LastRefreshDate>2026-03-01</LastRefreshDate>
            <RefreshFrequency>MONTHLY</RefreshFrequency>
            <RefreshDay>1</RefreshDay>
            <RefreshTime>03:00 ET</RefreshTime>
            <RefreshSource>REGULATORY_REFERENCE_MASTER</RefreshSource>
            <RecordCount>89</RecordCount>
        </RefreshConfiguration>

        <ExemptionCategories>
            <!-- Per 12 CFR 252.77(a)(4) — exemptions from SCCL -->
            <Category code="US_GOVT" description="U.S. government (including agencies, Fannie Mae, Freddie Mac while in conservatorship)">
                <RegulatoryReference>12 CFR 252.77(a)(4)(i)</RegulatoryReference>
                <ExemptFromLimitTest>true</ExemptFromLimitTest>
                <StillReportOnForm>true</StillReportOnForm>
            </Category>
            <Category code="FOREIGN_SOV_ZERO_RW" description="Foreign sovereign entities assigned zero percent risk weight under Board capital rules">
                <RegulatoryReference>12 CFR 252.77(a)(4)(ii)</RegulatoryReference>
                <ExemptFromLimitTest>true</ExemptFromLimitTest>
                <StillReportOnForm>true</StillReportOnForm>
                <!-- NOTE FOR RCA AGENT:
                     Risk weight assignments are sourced from the Board's capital rules
                     (12 CFR Part 217). A sovereign that loses zero-RW status (e.g.,
                     downgrade below investment grade) should lose its SCCL exemption.
                     The exemption table checks sovereign_risk_weight from a separate
                     reference feed. If that feed is stale, a sovereign could be
                     incorrectly marked exempt when its risk weight is no longer zero.
                     Not currently a break but a known risk vector for future monitoring. -->
            </Category>
            <Category code="INTRADAY" description="Intraday credit exposures">
                <RegulatoryReference>12 CFR 252.77(a)(4)(iii)</RegulatoryReference>
                <ExemptFromLimitTest>true</ExemptFromLimitTest>
                <StillReportOnForm>false</StillReportOnForm>
            </Category>
            <Category code="QUALIFYING_CCP" description="Trade exposures to qualifying central counterparties">
                <RegulatoryReference>12 CFR 252.77(a)(4)(iv)</RegulatoryReference>
                <ExemptFromLimitTest>true</ExemptFromLimitTest>
                <StillReportOnForm>true</StillReportOnForm>
            </Category>
            <Category code="BIS" description="Bank for International Settlements">
                <RegulatoryReference>12 CFR 252.77(a)(4)(v)</RegulatoryReference>
                <ExemptFromLimitTest>true</ExemptFromLimitTest>
                <StillReportOnForm>true</StillReportOnForm>
            </Category>
            <Category code="IMF" description="International Monetary Fund">
                <RegulatoryReference>12 CFR 252.77(a)(4)(v)</RegulatoryReference>
                <ExemptFromLimitTest>true</ExemptFromLimitTest>
                <StillReportOnForm>true</StillReportOnForm>
            </Category>
            <Category code="TEMP_EXEMPTION" description="Temporary credit exposure limit exemption granted by the Board">
                <RegulatoryReference>12 CFR 252.77(b)</RegulatoryReference>
                <ExemptFromLimitTest>true</ExemptFromLimitTest>
                <StillReportOnForm>true</StillReportOnForm>
                <RequiresNotice>true</RequiresNotice>
                <NoticeForm>FR 2590 Notice Requirements</NoticeForm>
            </Category>
        </ExemptionCategories>

        <ExemptionValidation>
            <ValidateRiskWeight>true</ValidateRiskWeight>
            <RiskWeightSource>AXIOM.CAPITAL.SOVEREIGN_RW_REF</RiskWeightSource>
            <RiskWeightRefreshFrequency>QUARTERLY</RiskWeightRefreshFrequency>
            <LastRiskWeightRefresh>2026-01-15</LastRiskWeightRefresh>
            <StaleRiskWeightAction>LOG_WARN_AND_CONTINUE</StaleRiskWeightAction>
            <!-- Risk weight reference is refreshed quarterly. If stale by >90 days,
                 warn but continue using last known risk weight. This is a pragmatic
                 choice but creates risk of incorrect exemption status for sovereigns
                 that have been downgraded between refresh cycles. -->
        </ExemptionValidation>

        <LimitComplianceCalculation>
            <Tier1CapitalSource>AXIOM.CAPITAL.TIER1_CAPITAL_QUARTERLY</Tier1CapitalSource>
            <LastTier1CapitalDate>2025-12-31</LastTier1CapitalDate>
            <Tier1CapitalAmount_USD_Thousands>42350000</Tier1CapitalAmount_USD_Thousands>
            <!-- $42.35B Tier 1 capital as of Q4 2025 -->
            <MajorLimit_USD_Thousands>6352500</MajorLimit_USD_Thousands>
            <!-- 15% × $42.35B = $6.35B -->
            <NonMajorLimit_USD_Thousands>10587500</NonMajorLimit_USD_Thousands>
            <!-- 25% × $42.35B = $10.59B -->
        </LimitComplianceCalculation>

    </ExemptionReferenceTable>

</AxiomSLConfiguration>
