<!-- FILE 2: IngestionFilters.xml                                  -->
<!-- ============================================================ -->
<AxiomSLConfiguration
    xmlns="http://www.axiomsl.com/controllerView/schema/v4.2"
    configType="IngestionFilters"
    module="FR2590_EXPOSURES"
    version="5.1.0"
    effectiveDate="2026-03-31"
    exportedAt="2026-04-10T08:00:00Z">

    <ConfigMetadata>
        <Description>Row-level ingestion filter rules for FR 2590 SCCL exposure feed. Determines which exposure records are included, excluded with warning, or silently excluded from the AxiomSL processing run. Filter evaluation order is top-down; first match wins.</Description>
    </ConfigMetadata>

    <IngestionFilters module="FR2590_EXPOSURES" evaluationOrder="SEQUENTIAL">

        <!-- FILTER 1: Missing beneficial owner on look-through exposures
             ADDED: v4.2.0 (2025-09-10, commit d4e8f21)
             ACTION: EXCLUDE
             LOGLEVEL: SILENT  <-- CRITICAL: NO LOG ENTRY GENERATED. Exposures are
                                   dropped from the submission with zero trace.
                                   This is the root cause of BRK-S04.
                                   8 securitization exposures with look_through_required=TRUE
                                   and beneficial_owner_lei=NULL are silently excluded
                                   as of 2026-04-04.
                                   Per 12 CFR 252.73(a)(6), look-through exposures must
                                   be attributed to the beneficial owner. If beneficial
                                   owner is unknown, the exposure should be reported as
                                   exposure to an "unknown counterparty" in Schedule G-5,
                                   NOT excluded from the filing entirely. -->
        <Filter id="BENEFICIAL_OWNER_NULL_EXCL" action="EXCLUDE" priority="10">
            <Description>Exclude securitization exposures where look-through is required but beneficial owner LEI is null. These are treated as data quality failures pending enrichment.</Description>
            <Rationale>Positions with look_through_required=TRUE but null beneficial_owner_lei cannot be correctly attributed to a counterparty for SCCL limit testing. Excluding prevents incorrect counterparty attribution.</Rationale>
            <AddedVersion>4.2.0</AddedVersion>
            <AddedDate>2025-09-10</AddedDate>
            <AddedTicket>JIRA-REG-4890</AddedTicket>
            <Condition>
                <Field>look_through_required</Field>
                <Operator>EQUALS</Operator>
                <Value>Y</Value>
                <AND>
                    <Field>beneficial_owner_lei</Field>
                    <Operator>IS_NULL</Operator>
                </AND>
            </Condition>
            <LogLevel>SILENT</LogLevel>
            <!-- SILENT = no log entry, no warning, no alert. Exposures simply absent. -->
            <AlertThreshold>0</AlertThreshold>
            <!-- AlertThreshold=0 means no alert even if many exposures are excluded. -->
            <AffectedSchedules>
                <Schedule>G-5</Schedule>
            </AffectedSchedules>
            <AffectedExposureTypes>
                <ExposureType>SECURITIZATION_LOOK_THROUGH</ExposureType>
                <ExposureType>CLO_LOOK_THROUGH</ExposureType>
                <ExposureType>ABCP_LOOK_THROUGH</ExposureType>
            </AffectedExposureTypes>
        </Filter>

        <!-- FILTER 2: Unmapped counterparty LEI
             ACTION: EXCLUDE
             LOGLEVEL: WARN  <-- This one at least logs a warning. BRK-S03. -->
        <Filter id="UNMAPPED_CPTY_EXCL" action="EXCLUDE" priority="20">
            <Description>Exclude exposure records where counterparty LEI is not present in the AxiomSL SCCL_CPTY_HIERARCHY reference table. Unmapped counterparties cannot be correctly grouped for economic interdependence or control relationship testing.</Description>
            <Condition>
                <Field>counterparty_lei</Field>
                <Operator>NOT_IN_TABLE</Operator>
                <ReferenceTable>AXIOM.FR2590.SCCL_CPTY_HIERARCHY</ReferenceTable>
                <ReferenceField>lei</ReferenceField>
                <WhereClause>active = 'Y'</WhereClause>
            </Condition>
            <LogLevel>WARN</LogLevel>
            <AlertThreshold>5</AlertThreshold>
            <!-- 3 subsidiaries of existing BHC counterparties onboarded in Snowflake
                 Feb-Mar 2026 not yet in SCCL_CPTY_HIERARCHY.
                 18 exposure records excluded as a result. WARN entries in application log.
                 = BRK-S03. -->
        </Filter>

        <!-- FILTER 3: Invalid exposure type code
             ACTION: REJECT (halts the run)
             LOGLEVEL: ERROR -->
        <Filter id="INVALID_EXPOSURE_TYPE" action="REJECT" priority="5">
            <Description>Reject entire ingestion run if any exposure record contains an exposure type code not in the FR 2590 approved exposure type list. This is a data integrity precondition.</Description>
            <Condition>
                <Field>exposure_type_code</Field>
                <Operator>NOT_IN_TABLE</Operator>
                <ReferenceTable>AXIOM.FR2590.EXPOSURE_TYPE_REF</ReferenceTable>
                <ReferenceField>exposure_type_code</ReferenceField>
                <WhereClause>is_active = 'Y'</WhereClause>
            </Condition>
            <LogLevel>ERROR</LogLevel>
            <AlertThreshold>0</AlertThreshold>
        </Filter>

        <!-- FILTER 4: Zero exposure amount
             ACTION: EXCLUDE
             LOGLEVEL: WARN -->
        <Filter id="ZERO_EXPOSURE_EXCL" action="EXCLUDE" priority="30">
            <Description>Exclude exposure records with zero or negative gross credit exposure amount. These are typically terminated or novated positions that should not appear in the submission.</Description>
            <Condition>
                <Field>gross_credit_exposure_usd</Field>
                <Operator>LESS_THAN_OR_EQUAL</Operator>
                <Value>0</Value>
            </Condition>
            <LogLevel>WARN</LogLevel>
            <AlertThreshold>50</AlertThreshold>
        </Filter>

        <!-- FILTER 5: Intraday exposures
             ACTION: EXCLUDE
             LOGLEVEL: INFO -->
        <Filter id="INTRADAY_EXCL" action="EXCLUDE" priority="40">
            <Description>Exclude intraday credit exposures per 12 CFR 252.77(a)(4)(iii) exemption. Intraday exposures are exempt from SCCL limits.</Description>
            <Condition>
                <Field>intraday_flag</Field>
                <Operator>EQUALS</Operator>
                <Value>Y</Value>
            </Condition>
            <LogLevel>INFO</LogLevel>
            <AlertThreshold>0</AlertThreshold>
        </Filter>

        <!-- FILTER 6: Exempt counterparty exposures below de minimis
             ACTION: EXCLUDE
             LOGLEVEL: INFO -->
        <Filter id="EXEMPT_BELOW_DEMINIMIS" action="EXCLUDE" priority="50">
            <Description>Exclude individual exposure records to exempt counterparties where gross credit exposure is below $1M de minimis threshold. Reduces processing volume without impact on limit compliance.</Description>
            <Condition>
                <Field>counterparty_exemption_status</Field>
                <Operator>EQUALS</Operator>
                <Value>EXEMPT</Value>
                <AND>
                    <Field>gross_credit_exposure_usd</Field>
                    <Operator>LESS_THAN</Operator>
                    <Value>1000000</Value>
                </AND>
            </Condition>
            <LogLevel>INFO</LogLevel>
            <AlertThreshold>0</AlertThreshold>
        </Filter>

    </IngestionFilters>

</AxiomSLConfiguration>


