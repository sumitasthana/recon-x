{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install --prefix reconx-ui",
  "buildCommand": "npm run build --prefix reconx-ui",
  "outputDirectory": "reconx-ui/dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
